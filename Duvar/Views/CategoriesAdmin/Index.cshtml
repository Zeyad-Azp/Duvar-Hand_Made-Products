@model List<Category>
@{
  ViewData["Title"] = "Categories";
  Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
  <p style="color:var(--brown-light);font-size:.9rem;margin:0;">
    @Model.Count categor@(Model.Count == 1 ? "y" : "ies") total
  </p>
  <a href="/my-admin/categories/create" class="btn-duvar btn-duvar-filled" style="font-size:.78rem;padding:.7rem 1.4rem;">
    <i class="bi bi-plus-lg"></i> New Category
  </a>
</div>

<div class="admin-table">
  <table class="table mb-0">
    <thead>
      <tr>
        <th>Image</th>
        <th>Name</th>
        <th>Description</th>
        <th>Products</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      @if (!Model.Any())
      {
        <tr>
          <td colspan="5" class="text-center" style="padding:3rem;color:var(--brown-light);">
            No categories yet. <a href="/my-admin/categories/create">Create the first one →</a>
          </td>
        </tr>
      }
      @foreach (var cat in Model)
      {
        <tr>
          <td>
            @if (!string.IsNullOrEmpty(cat.ImagePath))
            {
              <img src="@cat.ImagePath" alt="@cat.Name" />
            }
            else
            {
              <div style="width:52px;height:52px;background:var(--ivory);border-radius:6px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-image" style="color:var(--tan);"></i>
              </div>
            }
          </td>
          <td style="font-family:var(--font-display);font-size:1.05rem;font-weight:400;">@cat.Name</td>
          <td style="max-width:260px;">
            @if (!string.IsNullOrEmpty(cat.Description))
            {
              <span style="font-size:.88rem;color:var(--brown-light);">
                @(cat.Description.Length > 80 ? cat.Description[..80] + "…" : cat.Description)
              </span>
            }
            else
            {
              <span style="color:var(--beige);font-size:.82rem;">—</span>
            }
          </td>
          <td>
            <a href="/Products?categoryId=@cat.Id" target="_blank"
               style="font-size:.8rem;letter-spacing:.08em;background:var(--ivory);padding:.25rem .7rem;border-radius:50px;color:var(--brown-dark);text-decoration:none;">
              @cat.Products.Count items
            </a>
          </td>
          <td>
            <div class="d-flex gap-2 align-items-center">
              <a href="/my-admin/categories/edit/@cat.Id"
                 style="display:inline-flex;align-items:center;gap:.3rem;font-size:.78rem;color:var(--brown-dark);text-decoration:none;background:var(--ivory);padding:.35rem .75rem;border-radius:6px;border:1px solid var(--beige);">
                <i class="bi bi-pencil"></i> Edit
              </a>
              <form action="/my-admin/categories/delete/@cat.Id" method="post"
                    onsubmit="return confirm('Delete category \'@cat.Name\'? This will also delete all its products.');"
                    style="margin:0;">
                @Html.AntiForgeryToken()
                <button type="submit"
                        style="display:inline-flex;align-items:center;gap:.3rem;font-size:.78rem;color:#9b3a3a;background:rgba(155,58,58,.07);padding:.35rem .75rem;border-radius:6px;border:1px solid rgba(155,58,58,.15);cursor:pointer;font-family:inherit;">
                  <i class="bi bi-trash3"></i> Delete
                </button>
              </form>
            </div>
          </td>
        </tr>
      }
    </tbody>
  </table>
</div>
