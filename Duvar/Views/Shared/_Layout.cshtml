<!DOCTYPE html>
<html lang="en" data-theme="">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — Duvar" : "Duvar — Handmade Artisan Goods")</title>
  <meta name="description" content="@(ViewData["MetaDesc"] ?? "Duvar handmade artisan goods — unique, beautiful, made by hand.")" />
  <link rel="icon" type="image/jpeg" href="~/images/LOGO.jpg" />
  <link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

  <!-- Site CSS -->
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

  <!-- Apply saved theme immediately (no flash) -->
  <script>
    (function(){
      var t = localStorage.getItem('duvar-theme');
      if (t === 'dark') document.documentElement.setAttribute('data-theme','dark');
    })();
  </script>

  @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="brand-loader" class="brand-loader-wrapper">
    <div class="brand-loader-content">
        <h1 class="brand-logo-text">DUVAR</h1> 
        
        <div class="loader-bar"></div>
    </div>
</div>
<!-- ── Navbar ──────────────────────────────────────────────────── -->
<nav class="duvar-nav navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand nav-brand" asp-controller="Home" asp-action="Index">
      DUVAR<span></span>
    </a>

    <div class="d-flex align-items-center gap-2 order-lg-last">
      <!-- Dark mode toggle -->
      <button class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <i class="bi bi-moon icon-moon"></i>
        <i class="bi bi-sun  icon-sun"></i>
      </button>

      <!-- Mobile hamburger -->
      <button class="navbar-toggler border-0 p-1" type="button"
              data-bs-toggle="collapse" data-bs-target="#mainNav"
              aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
        <i class="bi bi-list fs-4" style="color:var(--text-primary);"></i>
      </button>
    </div>

    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav mx-auto align-items-lg-center gap-lg-1">
        <li class="nav-item">
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
             asp-controller="Home" asp-action="Index">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")"
             asp-controller="Categories" asp-action="Index">Categories</a>
        </li>
        <li class="nav-item">
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")"
             asp-controller="Products" asp-action="Index">Products</a>
        </li>
        <li class="nav-item">
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "About" ? "active" : "")"
             asp-controller="About" asp-action="Index">About</a>
        </li>
        <li class="nav-item">
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contact" ? "active" : "")"
             asp-controller="Contact" asp-action="Index">Contact</a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<!-- ── Page Content ─────────────────────────────────────────────── -->
<main>
  @RenderBody()
</main>

<!-- ── Footer ───────────────────────────────────────────────────── -->
<footer class="site-footer">
  <div class="container">
    <div class="row gy-4">
      <div class="col-lg-4">
        <div class="footer-brand">DUVAR</div>
        <div class="footer-tagline mb-3">Handmade with intention</div>
        <p style="color:rgba(232,213,183,.55);font-size:.88rem;line-height:1.8;max-width:280px;">
          Each piece is carefully crafted by hand, bringing warmth and artisan beauty into your home.
        </p>
      </div>
      <div class="col-lg-2 col-6">
        <div class="footer-heading">Navigate</div>
        <a class="footer-link" asp-controller="Home"       asp-action="Index">Home</a>
        <a class="footer-link" asp-controller="Categories" asp-action="Index">Categories</a>
        <a class="footer-link" asp-controller="Products"   asp-action="Index">All Products</a>
      </div>
      <div class="col-lg-2 col-6">
        <div class="footer-heading">Studio</div>
        <a class="footer-link" asp-controller="About"   asp-action="Index">About</a>
        <a class="footer-link" asp-controller="Contact" asp-action="Index">Contact</a>
      </div>
      <div class="col-lg-4">
        <div class="footer-heading">Get in Touch</div>
        <p style="color:rgba(232,213,183,.55);font-size:.88rem;line-height:1.8;">
          Interested in a custom piece or have a question? We'd love to hear from you.
        </p>
        <a asp-controller="Contact" asp-action="Index"
           class="btn-duvar mt-2 d-inline-flex"
           style="font-size:.72rem;padding:.65rem 1.5rem;border-color:rgba(232,213,183,.35);color:var(--cream);">
          Write to us <i class="bi bi-arrow-right"></i>
        </a>
      </div>
    </div>
    <hr class="footer-divider" />
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
      <span class="footer-copy">&copy; @DateTime.Now.Year Duvar. All rights reserved.</span>
      <span class="footer-copy">Handmade with care</span>
    </div>
  </div>
</footer>

<!-- ── Lightbox ──────────────────────────────────────────────────── -->
<div id="lightbox-overlay" class="lightbox-overlay" aria-modal="true" role="dialog">
  <button class="lightbox-close" aria-label="Close"><i class="bi bi-x-lg"></i></button>
  <button class="lightbox-nav lightbox-prev" aria-label="Previous"><i class="bi bi-chevron-left"></i></button>
  <img class="lightbox-img" src="" alt="Product image" />
  <button class="lightbox-nav lightbox-next" aria-label="Next"><i class="bi bi-chevron-right"></i></button>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- Site JS -->
<script src="~/js/site.js" asp-append-version="true"></script>
@* Animation *@
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const loader = document.getElementById('brand-loader');
        
        if (loader) {
            const displayTime = 600; 

            setTimeout(() => {
                
                loader.classList.add('fade-out');
                setTimeout(() => {
                    loader.remove();
                }, 500); 
            }, displayTime);
        }
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
