<!DOCTYPE html>
<html lang="en" data-theme="">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@(ViewData["Title"] ?? "Admin") — Duvar Admin</title>
  <link rel="icon" type="image/jpeg" href="~/images/LOGO.jpg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

  <!-- Apply saved theme immediately (no flash) -->
  <script>
    (function(){
      var t = localStorage.getItem('duvar-theme');
      if (t === 'dark') document.documentElement.setAttribute('data-theme','dark');
    })();
  </script>
</head>
<body>

<!-- ── Admin Sidebar ──────────────────────────────────────────── -->
<aside class="admin-sidebar">
  <div class="admin-sidebar-brand">
    <h2>DUVAR</h2>
    <p>Admin Panel</p>
  </div>

  <nav class="flex-grow-1 py-2">
    <div class="admin-nav-section">Overview</div>
    <a href="/my-admin/mydashboard"
       class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
      <i class="bi bi-grid-1x2"></i> Dashboard
    </a>

    <div class="admin-nav-section mt-2">Catalogue</div>
    <a href="/my-admin/categories"
       class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "CategoriesAdmin" ? "active" : "")">
      <i class="bi bi-folder2"></i> Categories
    </a>
    <a href="/my-admin/products"
       class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ProductsAdmin" ? "active" : "")">
      <i class="bi bi-box-seam"></i> Products
    </a>

    <div class="admin-nav-section mt-2">Site</div>
    <a href="/" target="_blank" class="admin-nav-link">
      <i class="bi bi-box-arrow-up-right"></i> View Site
    </a>

    <form action="/my-admin/logout" method="post" style="margin:0;">
      @Html.AntiForgeryToken()
      <button type="submit" class="admin-nav-link w-100 border-0" style="text-align:left;background:transparent;cursor:pointer;">
        <i class="bi bi-box-arrow-left"></i> Logout
      </button>
    </form>
  </nav>
</aside>

<!-- ── Admin Main ─────────────────────────────────────────────── -->
<div class="admin-main">

  <!-- Topbar -->
  <div class="admin-topbar">
    <span class="admin-topbar-title">@(ViewData["Title"] ?? "Dashboard")</span>

    <div class="d-flex align-items-center gap-3">
      <!-- Dark mode toggle -->
      <button class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <i class="bi bi-moon icon-moon"></i>
        <i class="bi bi-sun  icon-sun"></i>
      </button>

      <span style="font-size:.8rem;color:var(--text-muted);">
        <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
      </span>
    </div>
  </div>

  <!-- TempData success toast -->
  @if (TempData["Success"] != null)
  {
    <div id="temp-toast" style="
      position:fixed;top:1.5rem;right:1.5rem;z-index:9999;
      background:var(--text-primary);color:var(--bg-page);
      border-radius:12px;padding:1rem 1.5rem;
      box-shadow:0 20px 60px rgba(0,0,0,.3);
      font-size:.88rem;border-left:3px solid var(--tan);
      max-width:320px;">
      <i class="bi bi-check-circle me-2" style="color:var(--tan);"></i>@TempData["Success"]
    </div>
  }

  <!-- Page content -->
  <div class="admin-content">
    @RenderBody()
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
