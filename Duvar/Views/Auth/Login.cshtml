@model LoginViewModel
@{
  Layout = null;
  ViewData["Title"] = "Admin Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Duvar Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="admin-login-page">
  <div class="admin-login-card">
    <!-- Brand -->
    <div class="text-center mb-5">
      <div style="font-family:var(--font-display);font-size:2.4rem;letter-spacing:.14em;color:var(--espresso);margin-bottom:.2rem;">DUVAR</div>
      <div style="font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--tan);">Admin Panel</div>
    </div>

    <!-- Validation errors -->
    @if (!ViewData.ModelState.IsValid)
    {
      <div style="background:rgba(217,112,112,.08);border:1px solid rgba(217,112,112,.3);border-radius:10px;padding:1rem 1.2rem;margin-bottom:1.5rem;font-size:.88rem;color:#9b3a3a;">
        <i class="bi bi-exclamation-circle me-1"></i>
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
          <span>@err.ErrorMessage</span>
        }
      </div>
    }

    <form asp-area="Admin" asp-controller="Auth" asp-action="Login" method="post">
      @Html.AntiForgeryToken()
      <div class="mb-4">
        <label class="form-label" style="font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--brown-light);font-weight:400;">Username</label>
        <input asp-for="Username" type="text"
               class="form-control"
               style="border:1.5px solid var(--beige);border-radius:10px;padding:.85rem 1.1rem;background:var(--warm-white);font-family:var(--font-body);font-size:.95rem;color:var(--espresso);"
               placeholder="Enter username" autocomplete="username" />
      </div>
      <div class="mb-5">
        <label class="form-label" style="font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--brown-light);font-weight:400;">Password</label>
        <input asp-for="Password" type="password"
               class="form-control"
               style="border:1.5px solid var(--beige);border-radius:10px;padding:.85rem 1.1rem;background:var(--warm-white);font-family:var(--font-body);font-size:.95rem;color:var(--espresso);"
               placeholder="Enter password" autocomplete="current-password" />
      </div>
      <button type="submit" class="btn-duvar btn-duvar-filled w-100 justify-content-center" style="border-radius:10px;padding:1rem;">
        Sign In <i class="bi bi-arrow-right"></i>
      </button>
    </form>

    <div class="text-center mt-4">
      <a href="/" style="font-size:.78rem;color:var(--brown-light);">← Back to site</a>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
