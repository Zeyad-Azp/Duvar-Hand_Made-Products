@model ProductFormViewModel
@{
  ViewData["Title"] = "Edit Product";
  Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
  <a href="/my-admin/products"
     style="font-size:.8rem;color:var(--brown-light);text-decoration:none;display:inline-flex;align-items:center;gap:.4rem;">
    <i class="bi bi-arrow-left"></i> Back to Products
  </a>
</div>

<form asp-area="Admin" asp-controller="ProductsAdmin" asp-action="Edit" asp-route-id="@Model.Id"
      method="post" enctype="multipart/form-data">
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="Id" />
  

  <!-- Hidden inputs for image management -->
  <input type="hidden" id="delete-image-ids" name="DeleteImageIds" value="" />
  <input type="hidden" id="main-image-id" name="MainImageIndex" value="@Model.MainImageIndex" />
  <input type="hidden" id="main-image-filename" name="MainImageFileName" value="" />

  <div class="row g-4">

    <!-- Left: Core fields -->
    <div class="col-lg-7">
      <div class="admin-form-card mb-4">
        <h3 style="font-family:var(--font-display);font-size:1.4rem;font-weight:400;color:var(--espresso);margin-bottom:1.5rem;">
          Product Details
        </h3>

        <div class="mb-4">
          <label asp-for="Name" class="form-label">Product Name *</label>
          <input asp-for="Name" class="form-control" />
          <span asp-validation-for="Name" class="text-danger" style="font-size:.8rem;"></span>
        </div>

        <div class="mb-4">
          <label asp-for="CategoryId" class="form-label">Category *</label>
          <select asp-for="CategoryId" class="form-select"
                  asp-items="@(new SelectList(Model.Categories, "Id", "Name", Model.CategoryId))">
            <option value="">— Select a category —</option>
          </select>
          <span asp-validation-for="CategoryId" class="text-danger" style="font-size:.8rem;"></span>
        </div>

        <div class="mb-4">
          <label asp-for="Price" class="form-label">Price (USD) *</label>
          <div class="input-group">
            <span class="input-group-text" style="background:var(--ivory);border:1.5px solid var(--beige);border-right:none;color:var(--brown-light);">$</span>
            <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" style="border-left:none;" />
          </div>
          <span asp-validation-for="Price" class="text-danger" style="font-size:.8rem;"></span>
        </div>

        <div class="mb-2">
          <label asp-for="Description" class="form-label">Description</label>
          <textarea asp-for="Description" class="form-control" rows="5"></textarea>
          <span asp-validation-for="Description" class="text-danger" style="font-size:.8rem;"></span>
        </div>
      </div>
    </div>

    <!-- Right: Image Management -->
    <div class="col-lg-5">
      <div class="admin-form-card">
        <h3 style="font-family:var(--font-display);font-size:1.4rem;font-weight:400;color:var(--espresso);margin-bottom:.5rem;">
          Images
        </h3>
        <p style="font-size:.8rem;color:var(--brown-light);margin-bottom:1.2rem;">
          <i class="bi bi-info-circle me-1"></i>
          Click an image to set it as <strong>main</strong>. Click
          <i class="bi bi-x text-danger"></i> to remove it.
        </p>

        <!-- Existing images -->
        @if (Model.ExistingImages.Any())
        {
          <div class="admin-img-grid mb-4" id="existing-images-grid">
            @foreach (var img in Model.ExistingImages.OrderByDescending(i => i.IsMainImage))
            {
              <div class="admin-img-item @(img.IsMainImage ? "is-main" : "")"
                   data-id="@img.Id" title="Click to set as main">
                <img src="@img.ImagePath" alt="Product image" />
                @if (img.IsMainImage)
                {
                  <span class="main-badge">Main</span>
                }
                <button class="delete-btn" type="button" title="Remove image">
                  <i class="bi bi-x"></i>
                </button>
              </div>
            }
          </div>
        }
        else
        {
          <p style="font-size:.85rem;color:var(--brown-light);text-align:center;padding:1rem;">
            No images yet.
          </p>
        }

        <!-- Add new images -->
        <div style="border:2px dashed var(--beige);border-radius:10px;padding:1.2rem;text-align:center;cursor:pointer;"
             onclick="document.getElementById('new-images-input').click()">
          <i class="bi bi-plus-circle" style="font-size:1.5rem;color:var(--tan);display:block;margin-bottom:.4rem;"></i>
          <p style="font-size:.82rem;color:var(--brown-light);margin:0;">Add more images</p>
        </div>
        <input type="file" id="new-images-input" name="NewImages" accept="image/*"
               multiple style="display:none;" />
        <div id="new-images-preview" class="admin-img-grid mt-3"></div>
      </div>
    </div>

    <!-- Action buttons (full width) -->
    <div class="col-12">
      <div class="d-flex gap-3">
        <button type="submit" class="btn-duvar btn-duvar-filled" style="padding:.8rem 2rem;">
          <i class="bi bi-check2"></i> Save Changes
        </button>
        <a href="/Products/Details/@Model.Id" target="_blank" class="btn-duvar btn-duvar-tan" style="padding:.8rem 1.5rem;">
          <i class="bi bi-eye"></i> Preview
        </a>
        <a href="/my-admin/products" class="btn-duvar" style="padding:.8rem 1.5rem;">
          Cancel
        </a>
      </div>
    </div>
  </div>
</form>

@section Scripts {
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const deleteInput = document.getElementById('delete-image-ids');
    const mainInput   = document.getElementById('main-image-id');

    // --- Existing Images Logic ---
    document.querySelectorAll('#existing-images-grid .admin-img-item').forEach(item => {
      // Click image → set as main
      item.addEventListener('click', e => {
        if (e.target.closest('.delete-btn')) return;
        document.querySelectorAll('.admin-img-item').forEach(i => {
          i.classList.remove('is-main');
          const b = i.querySelector('.main-badge');
          if (b) b.remove();
        });
        item.classList.add('is-main');
        const badge = document.createElement('span');
        badge.className = 'main-badge';
        badge.textContent = 'Main';
        item.prepend(badge);
        mainInput.value = item.dataset.id;
        document.getElementById('main-image-filename').value = '';
      });

      // Delete button
      const delBtn = item.querySelector('.delete-btn');
      if (delBtn) {
        delBtn.addEventListener('click', e => {
          e.stopPropagation();
          item.style.opacity = '.25';
          item.style.pointerEvents = 'none';
          const cur = deleteInput.value ? deleteInput.value.split(',') : [];
          if (!cur.includes(item.dataset.id)) cur.push(item.dataset.id);
          deleteInput.value = cur.filter(Boolean).join(',');
        });
      }
    });

    // --- New Images Accumulation Logic ---
    const newInput = document.getElementById('new-images-input');
    const previewContainer = document.getElementById('new-images-preview');
    let dataTransfer = new DataTransfer(); // FIX 3: Holds accumulated files

    if (newInput) {
      newInput.addEventListener('change', function () {
        if (!previewContainer) return;

        // Add newly selected files to our DataTransfer object
        Array.from(this.files).forEach(file => {
            dataTransfer.items.add(file);
        });

        // Update the actual input with the accumulated files
        this.files = dataTransfer.files;
        renderNewImagesPreview();
      });

      // Handle removing a newly added file before upload
      previewContainer.addEventListener('click', function(e) {
         const removeBtn = e.target.closest('.remove-new-btn');
         if (removeBtn) {
             const indexToRemove = parseInt(removeBtn.dataset.index);
             const newDataTransfer = new DataTransfer();
             
             // Rebuild DataTransfer skipping the removed file
             for (let i = 0; i < dataTransfer.files.length; i++) {
                 if (i !== indexToRemove) {
                     newDataTransfer.items.add(dataTransfer.files[i]);
                 }
             }
             
             dataTransfer = newDataTransfer;
             newInput.files = dataTransfer.files;
             renderNewImagesPreview();
         }
      });
      
      function renderNewImagesPreview() {
        previewContainer.innerHTML = '';
        Array.from(dataTransfer.files).forEach((file, index) => {
          const reader = new FileReader();
          reader.onload = ev => {
            const div = document.createElement('div');
            div.className = 'admin-img-item';
            div.style.opacity = '.8';
            div.style.position = 'relative';
            div.title = 'Click to set as main';
            div.innerHTML = `
                <img src="${ev.target.result}" alt="new" />
                <button class="delete-btn remove-new-btn" type="button" data-index="${index}" title="Remove image">
                    <i class="bi bi-x"></i>
                </button>
            `;
            
            // Check if this was previously selected as main
            if (document.getElementById('main-image-filename').value === file.name) {
                div.classList.add('is-main');
                const badge = document.createElement('span');
                badge.className = 'main-badge';
                badge.textContent = 'Main';
                div.prepend(badge);
            }

            div.addEventListener('click', e => {
               if (e.target.closest('.delete-btn')) return;
               document.querySelectorAll('.admin-img-item').forEach(i => {
                   i.classList.remove('is-main');
                   const b = i.querySelector('.main-badge');
                   if (b) b.remove();
               });
               div.classList.add('is-main');
               const badge = document.createElement('span');
               badge.className = 'main-badge';
               badge.textContent = 'Main';
               div.prepend(badge);

               document.getElementById('main-image-filename').value = file.name;
               mainInput.value = '';
            });

            previewContainer.appendChild(div);
          };
          reader.readAsDataURL(file);
        });
      }
    }
  });
</script>
}